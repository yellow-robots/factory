# Copy to ~/.config/dev-runner/dispatch.env and `chmod 600`. NOT committed — holds the shared secret.
#
# The bearer token n8n must send (generate a long random one; the same value goes in the n8n HTTP node).
DISPATCH_TOKEN=CHANGE_ME_long_random_shared_with_n8n
#
# Bind to an interface the n8n CONTAINER can reach — a docker bridge gateway, NOT 127.0.0.1.
# n8n runs on caddy_caddy-net here (gateway 172.19.0.1, same as the Joam TG webhook). VERIFY for this host:
#   docker inspect <n8n-container> --format '{{range .NetworkSettings.Networks}}{{.Gateway}} {{end}}'
DISPATCH_BIND=172.19.0.1
DISPATCH_PORT=8770
#
# The spawned dev-runner needs these on PATH (claude, gh, git); the service env is otherwise minimal.
PATH=/home/jbrey/.local/bin:/home/linuxbrew/.linuxbrew/bin:/usr/bin:/bin
#
# No DEFAULT_REPO: dispatch is fail-closed (RFC 0006). The repo comes from the request payload
# (n8n reads each issue's repository); a request without an explicit owner/name repo never builds.
